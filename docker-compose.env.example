# Docker Compose Environment Configuration
# Copy to docker-compose.env and customize for your environment
# This file is loaded by: docker compose --env-file docker-compose.env ...

# =============================================================================
# csp-audit Services
# =============================================================================
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=replace-me
SUPABASE_REQUEST_TIMEOUT_MS=8000
REPORT_VIEWER_BASE_URL=http://localhost:3000

# Shared Agent API token (used by csp-audit services and hermes-gateway)
AGENT_TOKEN=replace-me

# Optional: viewer HTTP basic auth
VIEWER_BASIC_AUTH_USER=
VIEWER_BASIC_AUTH_PASSWORD=
VIEWER_SESSION_SECRET=

# =============================================================================
# Hermes Gateway (optional, required only if using --profile hermes-gateway)
# =============================================================================

# csp-audit Agent API endpoint (for task claiming, heartbeat, event posting)
CSP_AUDIT_BASE_URL=http://csp-report-viewer:3000
CSP_AUDIT_AGENT_NAME=hermes-gateway
CSP_AUDIT_AGENT_MODEL=hermes-gateway
CSP_AUDIT_AGENT_PROFILE=default
CSP_AUDIT_HEARTBEAT_INTERVAL_SECONDS=30

# Optional local API bridge. Disabled by default so the gateway does not consume tasks accidentally.
# When enabled, current mode is receipt-only: it proves claim/event/report/status plumbing
# without performing external testing against the target.
CSP_AUDIT_TASK_POLL_ENABLED=false
CSP_AUDIT_TASK_POLL_INTERVAL_SECONDS=60
CSP_AUDIT_TASK_EXECUTION_MODE=receipt

# LLM Provider (REQUIRED for Hermes to function — choose one):
# OpenRouter (recommended): https://openrouter.ai/keys
OPENROUTER_API_KEY=

# Or: Google Gemini: https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=

# Or: Ollama Cloud: https://ollama.com/settings
OLLAMA_API_KEY=

# UQLM Layer 2: model used for independent enrichment verification (requires Ollama)
UQLM_MODEL=qwen2.5:32b
OLLAMA_BASE_URL=http://host.docker.internal:11434

# Messaging Platforms (optional — only if gateway should listen on these):
TELEGRAM_BOT_TOKEN=
DISCORD_BOT_TOKEN=
SLACK_BOT_TOKEN=
WHATSAPP_BOT_TOKEN=
SIGNAL_BOT_TOKEN=
MATRIX_BOT_TOKEN=

# For details on each credential, see:
# - docs/integrations/hermes-gateway-credentials.md (seed and update credentials)
# - docs/integrations/hermes-gateway-api-integration.md (API wiring and task claiming)
